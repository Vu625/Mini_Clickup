Thumbs.db
*.log

# =================================================================
# BACKEND (FastAPI / Python)
# =================================================================
backend/__pycache__/
backend/*.py[cod]
backend/*$py.class
backend/.venv/
backend/venv/
backend/env/
backend/build/
backend/dist/
