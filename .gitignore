# Alembic migrations (giữ lại versions, nhưng bỏ qua cache)
backend/migrations/versions/__pycache__/

# =================================================================
# FRONTEND (Next.js / Node)
# =================================================================
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/dist/
frontend/.vercel/
frontend/*.tsbuildinfo
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*

# =================================================================
# ENVIRONMENT & SECRETS (QUAN TRỌNG: Không để lộ Gemini API Key)
# =================================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env
frontend/.env
frontend/.env.local

